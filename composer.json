{
  "name": "amp-framework/ampf",
  "description": "ampf MVC PHP framework",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "ampf\\": "src/ampf/",
      "ampfTest\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.5",
    "ext-pdo": "*",
    "doctrine/orm": "^3.6",
    "symfony/cache": "^8.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13.1",
    "slevomat/coding-standard": "^8.29"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
